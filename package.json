{
  "name": "@henkisdabro/mcp-selector",
  "version": "2.5.1",
  "description": "MCP Server Selector TUI for Claude Code",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "mcp": "dist/cli.js",
    "claudemcp": "dist/cli.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "esbuild src/cli/index.ts --bundle --platform=node --target=node24 --outfile=dist/cli.js --format=esm --external:ink --external:react --external:react-devtools-core --external:yoga-wasm-web --external:yoga-layout-prebuilt --external:@inkjs/ui --external:ink-spinner --external:zustand --external:chalk --external:supports-color --external:commander --external:fuse.js --external:proper-lockfile",
    "build:prod": "npm run build -- --minify",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@inkjs/ui": "2.0.0",
    "chalk": "5.6.2",
    "commander": "14.0.3",
    "fuse.js": "7.3.0",
    "ink": "6.8.0",
    "ink-spinner": "5.0.0",
    "proper-lockfile": "4.1.2",
    "react": "19.2.6",
    "supports-color": "10.2.2",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "@types/proper-lockfile": "4.1.4",
    "@types/react": "19.2.14",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "@vitest/coverage-v8": "4.1.5",
    "esbuild": "0.28.0",
    "eslint": "9.39.4",
    "ink-testing-library": "4.0.0",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.2",
    "vitest": "4.1.5"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "mcp",
    "claude",
    "tui",
    "cli",
    "server-selector",
    "anthropic"
  ],
  "author": "Henrik Soederlund",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henkisdabro/Claude-Code-MCP-Server-Selector.git"
  },
  "bugs": {
    "url": "https://github.com/henkisdabro/Claude-Code-MCP-Server-Selector/issues"
  },
  "homepage": "https://github.com/henkisdabro/Claude-Code-MCP-Server-Selector#readme"
}
